CREATE TABLE IF NOT EXISTS agenda (CDDATA DATETIME, OBS1 VARCHAR(60), OBS2 VARCHAR(60), OBS3 VARCHAR(60), OBS4 VARCHAR(60), OBS5 VARCHAR(60), OBS6 VARCHAR(60), OBS7 VARCHAR(60), OBS8 VARCHAR(60))

create index AGENDA on agenda ( CDDATA ) ;

