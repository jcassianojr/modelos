DBFDEF AGENDA
   CDDATA     D   8  0
   OBS1       C  60  0
   OBS2       C  60  0
   OBS3       C  60  0
   OBS4       C  60  0
   OBS5       C  60  0
   OBS6       C  60  0
   OBS7       C  60  0
   OBS8       C  60  0
ENDDEF
DEFINDEX AGENDA
   AGENDA CDDATA CDDATA
ENDINDEX
ENDFILE

[AGENDA.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=1
MAINTAIN0=agenda.CDX
TAG0=AGENDA
INDEX0=CDDATA
INDEXFIELDS0=CDDATA

[SQLITE]
CREATE TABLE IF NOT EXISTS agenda (CDDATA DATE, OBS1 TEXT , OBS2 TEXT , OBS3 TEXT , OBS4 TEXT , OBS5 TEXT , OBS6 TEXT , OBS7 TEXT , OBS8 TEXT )

create index AGENDA on agenda ( CDDATA ) ;

