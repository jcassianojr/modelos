[DBML]
Table mexpor {
"ARQORI" CHAR (8)
"ARQDES" CHAR (8)
"CODIGO" CHAR (6)
"DESCRICAO" CHAR (50)
"CHAVEIND" CHAR (30)
"DESAPP" CHAR (10)
"ORIAPP" CHAR (40)
"REPENC" CHAR (1)
"APAGA" CHAR (1)
"TIPO" CHAR (1)
"ARQORIEXT" CHAR (3)
"ARQDESEXT" CHAR (3)
  Indexes {
 ( CODIGO )  [name: "MEXPOR"]

 }
}
