CREATE TABLE IF NOT EXISTS mn99 (NUMERO INTEGER default 0, NRNOTA INTEGER default 0, TIPFAT TEXT , OPERACAO TEXT , DATA DATE, FORNECEDO INTEGER default 0, COGNOME TEXT , PEDIDO FLOAT, DDD TEXT , TELEFONE TEXT , VENDEDOR TEXT , TOTNF FLOAT, SITUACAO INTEGER default 0, BANCO TEXT , NOMEBCO TEXT , DOCBOL TEXT , DOCDUP TEXT , VENCIMENT DATE, VALOR FLOAT, NOTA INTEGER default 0, DOCABATE INTEGER default 0, ABATER FLOAT, TAXA FLOAT, DIAS INTEGER default 0, JUROS FLOAT, JURVAL FLOAT, VALATUAL FLOAT, OBS TEXT , OBS1 TEXT , OBS2 TEXT , OBS3 TEXT , OBS4 TEXT , DATAPG DATE, VALORPG FLOAT, DIFERENCA FLOAT, NF_COMPLE TEXT , CODCOMP TEXT , IMPDUP TEXT , PREVATR INTEGER default 0, FLUXO TEXT , TIPOCLI TEXT , BCODEP INTEGER default 0, AGCDEP TEXT , CTADEP TEXT , CONTA TEXT , GERACOB TEXT , MES INTEGER default 0, ANO INTEGER default 0)

create index MN99_1 on mn99 ( VENCIMENT,NUMERO,TIPFAT ) ;
create index MN99_2 on mn99 ( DATAPG,NUMERO,TIPFAT ) ;
create index MN99_3 on mn99 ( FORNECEDO,NUMERO ) ;
create index MN99_4 on mn99 ( BANCO,DATAPG ) ;

