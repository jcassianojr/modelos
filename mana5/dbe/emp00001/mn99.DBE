DBFDEF MN99
   NUMERO     N   8  0
   NRNOTA     N   8  0
   TIPFAT     C   1  0
   OPERACAO   C  21  0
   DATA       D   8  0
   FORNECEDO  N   5  0
   COGNOME    C  12  0
   PEDIDO     N   8  2
   DDD        C   4  0
   TELEFONE   C   9  0
   VENDEDOR   C   5  0
   TOTNF      N  12  2
   SITUACAO   N   2  0
   BANCO      C   3  0
   NOMEBCO    C  12  0
   DOCBOL     C  15  0
   DOCDUP     C  15  0
   VENCIMENT  D   8  0
   VALOR      N  12  2
   NOTA       N   8  0
   DOCABATE   N   8  0
   ABATER     N  12  2
   TAXA       N   6  4
   DIAS       N   3  0
   JUROS      N  12  2
   JURVAL     N  12  2
   VALATUAL   N  12  2
   OBS        C  55  0
   OBS1       C  70  0
   OBS2       C  70  0
   OBS3       C  70  0
   OBS4       C  70  0
   DATAPG     D   8  0
   VALORPG    N  12  2
   DIFERENCA  N  12  2
   NF_COMPLE  C  40  0
   CODCOMP    C   1  0
   IMPDUP     C   1  0
   PREVATR    N   5  0
   FLUXO      C   1  0
   TIPOCLI    C   1  0
   BCODEP     N   3  0
   AGCDEP     C   6  0
   CTADEP     C   6  0
   CONTA      C  12  0
   GERACOB    C   1  0
   MES        N   2  0
   ANO        N   4  0
ENDDEF
DEFINDEX MN99
   MN99-1 DTOS(VENCIMENT)+STR(NUMERO,8)+TIPFAT VENCIMENT,NUMERO,TIPFAT
   MN99-2 DTOS(DATAPG)+STR(NUMERO,8)+TIPFAT DATAPG,NUMERO,TIPFAT
   MN99-3 STR(FORNECEDO,5)+STR(NUMERO,8) FORNECEDO,NUMERO
   MN99-4 BANCO+DTOS(DATAPG) BANCO,DATAPG
ENDINDEX
ENDFILE

[MN99.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=4
MAINTAIN0=mn99.CDX
TAG0=MN99-1
INDEX0=DTOS(VENCIMENT)+STR(NUMERO,8)+TIPFAT
INDEXFIELDS0=VENCIMENT,NUMERO,TIPFAT
TAG1=MN99-2
INDEX1=DTOS(DATAPG)+STR(NUMERO,8)+TIPFAT
INDEXFIELDS1=DATAPG,NUMERO,TIPFAT
TAG2=MN99-3
INDEX2=STR(FORNECEDO,5)+STR(NUMERO,8)
INDEXFIELDS2=FORNECEDO,NUMERO
TAG3=MN99-4
INDEX3=BANCO+DTOS(DATAPG)
INDEXFIELDS3=BANCO,DATAPG

