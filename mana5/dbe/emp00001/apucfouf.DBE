DBFDEF APUCFOUF
   CFO        C   3  0
   CFONEW     C   4  0
   SUBCFO     C   1  0
   UF         C   2  0
   DESCRICAO  C  40  0
   CONTABIL   N  12  2
   BASE       N  12  2
   VALOR      N  12  2
   ISENTA     N  12  2
   OUTRA      N  12  2
   OBS        N  12  2
   UFGIA      C   2  0
ENDDEF
DEFINDEX APUCFOUF
   APUCFOU1 CFO+SUBCFO+UF CFO,SUBCFO,UF
   APUCFOU2 CFONEW+UF CFONEW,UF
   APUCFOU3 CFONEW+UFGIA CFONEW,UFGIA
ENDINDEX
ENDFILE

[APUCFOUF.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=3
MAINTAIN0=apucfouf.CDX
TAG0=APUCFOU1
INDEX0=CFO+SUBCFO+UF
INDEXFIELDS0=CFO,SUBCFO,UF
TAG1=APUCFOU2
INDEX1=CFONEW+UF
INDEXFIELDS1=CFONEW,UF
TAG2=APUCFOU3
INDEX2=CFONEW+UFGIA
INDEXFIELDS2=CFONEW,UFGIA

[SQLITE]
CREATE TABLE IF NOT EXISTS apucfouf (CFO TEXT , CFONEW TEXT , SUBCFO TEXT , UF TEXT , DESCRICAO TEXT , CONTABIL FLOAT, BASE FLOAT, VALOR FLOAT, ISENTA FLOAT, OUTRA FLOAT, OBS FLOAT, UFGIA TEXT )

create index APUCFOU1 on apucfouf ( CFO,SUBCFO,UF ) ;
create index APUCFOU2 on apucfouf ( CFONEW,UF ) ;
create index APUCFOU3 on apucfouf ( CFONEW,UFGIA ) ;

