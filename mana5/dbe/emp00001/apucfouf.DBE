[DBML]
Table apucfouf {
"CFO" CHAR (3)
"CFONEW" CHAR (4)
"SUBCFO" CHAR (1)
"UF" CHAR (2)
"DESCRICAO" CHAR (40)
"CONTABIL" DECIMAL (12,2) [default: 0]
"BASE" DECIMAL (12,2) [default: 0]
"VALOR" DECIMAL (12,2) [default: 0]
"ISENTA" DECIMAL (12,2) [default: 0]
"OUTRA" DECIMAL (12,2) [default: 0]
"OBS" DECIMAL (12,2) [default: 0]
"UFGIA" CHAR (2)
  Indexes {
 ( CFO,SUBCFO,UF )  [name: "APUCFOU1"]
 ( CFONEW,UF )  [name: "APUCFOU2"]
 ( CFONEW,UFGIA )  [name: "APUCFOU3"]

 }
}
