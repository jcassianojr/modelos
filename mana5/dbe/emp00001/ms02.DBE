create index MS02_5 on ms02 ( CODIGO,FORNECEDO,DATA ) ;

[DBML]
Table ms02 {
"CODIGO" CHAR (24)
"FORNECEDO" DECIMAL (5) [default: 0]
"COMPRA" CHAR (9)
"TIPOCLI" CHAR (1)
"DATA" DATETIME 
"TIPO" CHAR (1)
"TIPI" CHAR (1)
"VALOR" DECIMAL (18,4) [default: 0]
"UNIDE" CHAR (2)
"COIDE" CHAR (2)
"ATUAL" CHAR (1)
"CLIFOR" DECIMAL (8) [default: 0]
  Indexes {
 ( CODIGO,FORNECEDO,COMPRA,DATA )  [name: "MS02_1"]
 ( CODIGO,FORNECEDO )  [name: "MS02_2"]
 ( CODIGO )  [name: "MS02_3"]
 ( CODIGO,DATA,DATA,DATA )  [name: "MS02_4"]
 ( CODIGO,FORNECEDO,DATA )  [name: "MS02_5"]

 }
}
