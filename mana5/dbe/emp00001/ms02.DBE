[ORACLE]
CREATE TABLE IF NOT EXISTS ms02 (CODIGO VARCHAR2 (24), FORNECEDO NUMBER(5)  DEFAULT 0, COMPRA VARCHAR2 (9), TIPOCLI VARCHAR2 (1), DATA DATE, TIPO VARCHAR2 (1), TIPI VARCHAR2 (1), VALOR NUMBER(18,4)  DEFAULT 0, UNIDE VARCHAR2 (2), COIDE VARCHAR2 (2), ATUAL VARCHAR2 (1), CLIFOR NUMBER(8)  DEFAULT 0)

create index MS02_1 on ms02 ( CODIGO,FORNECEDO,COMPRA,DATA ) ;
create index MS02_2 on ms02 ( CODIGO,FORNECEDO ) ;
create index MS02_3 on ms02 ( CODIGO ) ;
