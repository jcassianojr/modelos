CREATE TABLE IF NOT EXISTS ms02 (CODIGO CHAR(24), FORNECEDO INTEGER(5), COMPRA CHAR(9), TIPOCLI CHAR(1), DATA DATE, TIPO CHAR(1), TIPI CHAR(1), VALOR NUMERIC(18,4), UNIDE CHAR(2), COIDE CHAR(2), ATUAL CHAR(1), CLIFOR INTEGER(8))

create index MS02_1 on ms02 ( CODIGO,FORNECEDO,COMPRA,DATA ) ;
create index MS02_2 on ms02 ( CODIGO,FORNECEDO ) ;
create index MS02_3 on ms02 ( CODIGO ) ;
create index MS02_4 on ms02 ( CODIGO,DATA,DATA,DATA ) ;
create index MS02_5 on ms02 ( CODIGO,FORNECEDO,DATA ) ;

