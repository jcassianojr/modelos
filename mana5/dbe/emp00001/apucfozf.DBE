CREATE TABLE IF NOT EXISTS apucfozf (NF NUMBER(6)  DEFAULT 0, DATA DATE, VALOR NUMBER(12,2)  DEFAULT 0, CNPJ VARCHAR2 (18), CODMUN VARCHAR2 (5))

