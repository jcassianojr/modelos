DBFDEF MP02A
   CODIGO     C  12  0
   SEQ        N   3  0
   CODMPSB    C  12  0
   NOMMPSB    C  30  0
ENDDEF
DEFINDEX MP02A
   MP02A-1 CODIGO+STR(SEQ,3) CODIGO,SEQ
   MP02A-2 CODMPSB+STR(SEQ,3) CODMPSB,SEQ
ENDINDEX
ENDFILE

[MP02A.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=2
MAINTAIN0=mp02a.CDX
TAG0=MP02A-1
INDEX0=CODIGO+STR(SEQ,3)
INDEXFIELDS0=CODIGO,SEQ
TAG1=MP02A-2
INDEX1=CODMPSB+STR(SEQ,3)
INDEXFIELDS1=CODMPSB,SEQ

[SQLITE]
CREATE TABLE IF NOT EXISTS mp02a (CODIGO TEXT , SEQ INTEGER default 0, CODMPSB TEXT , NOMMPSB TEXT )

create index MP02A_1 on mp02a ( CODIGO,SEQ ) ;
create index MP02A_2 on mp02a ( CODMPSB,SEQ ) ;

