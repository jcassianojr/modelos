create index MP02A_2 on mp02a ( CODMPSB,SEQ ) ;

[DBML]
Table mp02a {
"CODIGO" CHAR (12)
"SEQ" DECIMAL (3) [default: 0]
"CODMPSB" CHAR (12)
"NOMMPSB" CHAR (30)
  Indexes {
 ( CODIGO,SEQ )  [name: "MP02A_1"]
 ( CODMPSB,SEQ )  [name: "MP02A_2"]

 }
