DBFDEF OC01A
   OC         N   8  0
   ITEM       N   3  0
   CODIGO     C  24  0
   QTDUNI     N   8  0
   QTDEMB     N   8  0
   PESUNI     N  12  3
   PESEMB     N  12  3
   SOMA       N  15  3
ENDDEF
DEFINDEX OC01A
   OC01A-1 STR(OC,8)+STR(ITEM,3) OC,ITEM
ENDINDEX
ENDFILE

[OC01A.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=1
MAINTAIN0=oc01a.CDX
TAG0=OC01A-1
INDEX0=STR(OC,8)+STR(ITEM,3)
INDEXFIELDS0=OC,ITEM

[SQLITE]
CREATE TABLE IF NOT EXISTS oc01a (OC INTEGER default 0, ITEM INTEGER default 0, CODIGO TEXT , QTDUNI INTEGER default 0, QTDEMB INTEGER default 0, PESUNI FLOAT, PESEMB FLOAT, SOMA FLOAT)

create index OC01A_1 on oc01a ( OC,ITEM ) ;

[MSSQL]
CREATE TABLE IF NOT EXISTS oc01a (OC INT, ITEM INT, CODIGO VARCHAR(24), QTDUNI INT, QTDEMB INT, PESUNI NUMERIC(12,3), PESEMB NUMERIC(12,3), SOMA NUMERIC(15,3))

create index OC01A_1 on oc01a ( OC,ITEM ) ;

[MYSQL]
CREATE TABLE IF NOT EXISTS oc01a (OC INTEGER(8), ITEM INTEGER(3), CODIGO CHAR(24), QTDUNI INTEGER(8), QTDEMB INTEGER(8), PESUNI NUMERIC(12,3), PESEMB NUMERIC(12,3), SOMA NUMERIC(15,3))

create index OC01A_1 on oc01a ( OC,ITEM ) ;

