CREATE TABLE IF NOT EXISTS OC01A (OC INTEGER, ITEM INTEGER, CODIGO VARCHAR(24), QTDUNI INTEGER, QTDEMB INTEGER, PESUNI NUMERIC(12,3), PESEMB NUMERIC(12,3), SOMA NUMERIC(15,3))

create index OC01A_1 on oc01a ( OC,ITEM ) ;

[ACCESS]
