create index MG04_1 on mg04 ( nummarca,modelo ) ;

[ORACLE]
CREATE TABLE IF NOT EXISTS mg04 (COD_IPVA NUMBER(7)  DEFAULT 0, TIPO NUMBER(1)  DEFAULT 0, FAIXA_IPVA NUMBER(2)  DEFAULT 0, LINHA NUMBER(4)  DEFAULT 0, COD_REF NUMBER(4)  DEFAULT 0, MARCA VARCHAR2 (20), MODELO VARCHAR2 (55), ORIGEM VARCHAR2 (3), NUMMARCA NUMBER(8)  DEFAULT 0, CATEGORIA VARCHAR2 (2), CAPACID NUMBER(3)  DEFAULT 0, CODFIPE VARCHAR2 (7))

create index MG04_1 on mg04 ( nummarca,modelo ) ;

[DBML]
Table mg04 {
"COD_IPVA" DECIMAL (7) [default: 0]
"TIPO" DECIMAL (1) [default: 0]
"FAIXA_IPVA" DECIMAL (2) [default: 0]
"LINHA" DECIMAL (4) [default: 0]
"COD_REF" DECIMAL (4) [default: 0]
"MARCA" CHAR (20)
"MODELO" CHAR (55)
"ORIGEM" CHAR (3)
"NUMMARCA" DECIMAL (8) [default: 0]
"CATEGORIA" CHAR (2)
"CAPACID" DECIMAL (3) [default: 0]
"CODFIPE" CHAR (7)
  Indexes {
 ( nummarca,modelo )  [name: "MG04_1"]

 }
}
