ENDFILE

[AGENDA.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=0
MAINTAIN0=agenda.CDX

[SQLITE]
CREATE TABLE IF NOT EXISTS agenda (CDDATA DATE, OBS1 TEXT , OBS2 TEXT , OBS3 TEXT , OBS4 TEXT , OBS5 TEXT , OBS6 TEXT , OBS7 TEXT , OBS8 TEXT )


[MSSQL]
CREATE TABLE IF NOT EXISTS agenda (CDDATA DATETIME, OBS1 VARCHAR(60), OBS2 VARCHAR(60), OBS3 VARCHAR(60), OBS4 VARCHAR(60), OBS5 VARCHAR(60), OBS6 VARCHAR(60), OBS7 VARCHAR(60), OBS8 VARCHAR(60))


[MYSQL]
CREATE TABLE IF NOT EXISTS agenda (CDDATA DATE, OBS1 CHAR(60), OBS2 CHAR(60), OBS3 CHAR(60), OBS4 CHAR(60), OBS5 CHAR(60), OBS6 CHAR(60), OBS7 CHAR(60), OBS8 CHAR(60))


[POSTGRESQL]
CREATE TABLE IF NOT EXISTS AGENDA (CDDATA TIMESTAMP, OBS1 VARCHAR(60), OBS2 VARCHAR(60), OBS3 VARCHAR(60), OBS4 VARCHAR(60), OBS5 VARCHAR(60), OBS6 VARCHAR(60), OBS7 VARCHAR(60), OBS8 VARCHAR(60))


[ACCESS]
