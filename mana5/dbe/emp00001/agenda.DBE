DBFDEF AGENDA
   CDDATA     D   8  0
   OBS1       C  60  0
   OBS2       C  60  0
   OBS3       C  60  0
   OBS4       C  60  0
   OBS5       C  60  0
   OBS6       C  60  0
   OBS7       C  60  0
   OBS8       C  60  0
