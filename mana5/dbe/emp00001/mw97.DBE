CREATE TABLE IF NOT EXISTS MW97 (ARQUIVO VARCHAR(8), DOCUMENTO VARCHAR(40), OPERACAO VARCHAR(1), USUARIO VARCHAR(5), QTDE NUMERIC(12,3), OLDQTDE NUMERIC(12,3), NUMERO INTEGER, DATA TIMESTAMP, CODIGO VARCHAR(24), RASTRO VARCHAR(10), ESTQXXX NUMERIC(12,3), ESTQYYY NUMERIC(12,3))

create index MW97_1 on mw97 ( ARQUIVO,DOCUMENTO ) ;
create index MW97_2 on mw97 ( CODIGO,DATA ) ;

