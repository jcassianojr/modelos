DBFDEF MY03A
   NUMERO     N   8  0
   ITEM       N   3  0
   CODPAR     C   3  0
   CODPARD    C   1  0
   PINI       N   5  2
   PFIM       N   5  2
   PALI       N   5  2
   PALF       N   5  2
   TEMPO      N   6  2
   OBS        C  78  0
ENDDEF
DEFINDEX MY03A
   MY03A-1 STR(NUMERO,8)+STR(ITEM,3) NUMERO,ITEM
ENDINDEX
ENDFILE

[MY03A.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=1
MAINTAIN0=my03a.CDX
TAG0=MY03A-1
INDEX0=STR(NUMERO,8)+STR(ITEM,3)
INDEXFIELDS0=NUMERO,ITEM

[SQLITE]
CREATE TABLE IF NOT EXISTS my03a (NUMERO INTEGER default 0, ITEM INTEGER default 0, CODPAR TEXT , CODPARD TEXT , PINI FLOAT, PFIM FLOAT, PALI FLOAT, PALF FLOAT, TEMPO FLOAT, OBS TEXT )

create index MY03A_1 on my03a ( NUMERO,ITEM ) ;

[MSSQL]
CREATE TABLE IF NOT EXISTS my03a (NUMERO INT, ITEM INT, CODPAR VARCHAR(3), CODPARD VARCHAR(1), PINI NUMERIC(5,2), PFIM NUMERIC(5,2), PALI NUMERIC(5,2), PALF NUMERIC(5,2), TEMPO NUMERIC(6,2), OBS VARCHAR(78))

create index MY03A_1 on my03a ( NUMERO,ITEM ) ;

