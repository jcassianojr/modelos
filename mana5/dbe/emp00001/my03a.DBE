"CODPARD" CHAR (1)
"PINI" DECIMAL (5,2) [default: 0]
"PFIM" DECIMAL (5,2) [default: 0]
"PALI" DECIMAL (5,2) [default: 0]
"PALF" DECIMAL (5,2) [default: 0]
"TEMPO" DECIMAL (6,2) [default: 0]
