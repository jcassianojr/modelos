   CIDPRO     C  35  0
   ESTPRO     C   2  0
   PESSOA     C   1  0
   CGC        C  18  0
   CEPPRO     C   9  0
ENDDEF
DEFINDEX MG03
   MG03-1 NUMERO+CODFRO NUMERO,CODFRO
ENDINDEX
ENDFILE

[MG03.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=1
MAINTAIN0=mg03.CDX
TAG0=MG03-1
INDEX0=NUMERO+CODFRO
INDEXFIELDS0=NUMERO,CODFRO

[SQLITE]
CREATE TABLE IF NOT EXISTS mg03 (NUMERO TEXT , CODEMP TEXT , CODFRO TEXT , CHAPAF TEXT , PROFRO TEXT , ANOMOD INTEGER default 0, ANOFRO INTEGER default 0, KMINI FLOAT, CHASSI TEXT , TIPFRO TEXT , MARFRO TEXT , MODFRO TEXT , COMFRO TEXT , RENAVAM TEXT , CATFRO TEXT , ESTFRO TEXT , CIDIPVA TEXT , CIDFRO TEXT , ESPFRO TEXT , CARFRO TEXT , CODIPVA INTEGER default 0, NOMPRO TEXT , ENDPRO TEXT , BAIPRO TEXT , CIDPRO TEXT , ESTPRO TEXT , PESSOA TEXT , CGC TEXT , CEPPRO TEXT )

create index MG03_1 on mg03 ( NUMERO,CODFRO ) ;

