create index MN01PG_1 on mn01pg ( VENCIMENT,NUMERO,TIPFAT ) ;
create index MN01PG_2 on mn01pg ( DATAPG,NUMERO,TIPFAT ) ;
create index MN01PG_3 on mn01pg ( FORNECEDO,NUMERO ) ;
