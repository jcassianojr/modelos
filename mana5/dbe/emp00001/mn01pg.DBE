ENDDEF
DEFINDEX MN01PG
   MN01PG-1 DTOS(VENCIMENT)+STR(NUMERO,8)+TIPFAT VENCIMENT,NUMERO,TIPFAT
   MN01PG-2 DTOS(DATAPG)+STR(NUMERO,8)+TIPFAT DATAPG,NUMERO,TIPFAT
   MN01PG-3 STR(FORNECEDO,5)+STR(NUMERO,8) FORNECEDO,NUMERO
   MN01PG-4 BANCO+DTOS(DATAPG) BANCO,DATAPG
   MN01PG-5 NUMERO NUMERO
ENDINDEX
ENDFILE

[MN01PG.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=5
