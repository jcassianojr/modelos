   TIPFAT     C   1  0
   OPERACAO   C  21  0
   DATA       D   8  0
   FORNECEDO  N   5  0
   COGNOME    C  12  0
   PEDIDO     N   8  2
   DDD        C   4  0
   TELEFONE   C   9  0
   VENDEDOR   C   5  0
   TOTNF      N  12  2
   SITUACAO   N   2  0
   BANCO      C   3  0
   NOMEBCO    C  12  0
   DOCBOL     C  15  0
   DOCDUP     C  15  0
   VENCIMENT  D   8  0
   VALOR      N  12  2
   NOTA       N   8  0
   DOCABATE   N   8  0
   ABATER     N  12  2
   TAXA       N   6  4
   DIAS       N   3  0
   JUROS      N  12  2
   JURVAL     N  12  2
