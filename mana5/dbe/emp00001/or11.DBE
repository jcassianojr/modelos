DBFDEF OR11
   CODIGO     C  24  0
   OS         N   8  2
   OF         N  12  2
   QTDDE      N  12  4
   REQUISI    N   8  0
   NRNOTA     N   5  0
   SEQ        N   3  0
   BAIXA      D   8  0
   TIPO       C   1  0
   QTDEBAI    N  12  4
   DLIMITE    D   8  0
   DPEDI      D   8  0
   DLIMP      D   8  0
   RASTRO     C   6  0
ENDDEF
DEFINDEX OR11
   OR11-1 CODIGO+STR(OS,8,2)+STR(REQUISI,8) CODIGO,OS,REQUISI
   OR11-2 STR(REQUISI,8)+STR(OS,8,2) REQUISI,OS
   OR11-3 CODIGO+DTOS(DLIMITE) CODIGO,DLIMITE
   OR11-4 CODIGO+DTOS(DLIMP) CODIGO,DLIMP
ENDINDEX
ENDFILE

[OR11.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=4
MAINTAIN0=or11.CDX
TAG0=OR11-1
INDEX0=CODIGO+STR(OS,8,2)+STR(REQUISI,8)
INDEXFIELDS0=CODIGO,OS,REQUISI
TAG1=OR11-2
INDEX1=STR(REQUISI,8)+STR(OS,8,2)
INDEXFIELDS1=REQUISI,OS
TAG2=OR11-3
INDEX2=CODIGO+DTOS(DLIMITE)
INDEXFIELDS2=CODIGO,DLIMITE
TAG3=OR11-4
INDEX3=CODIGO+DTOS(DLIMP)
INDEXFIELDS3=CODIGO,DLIMP

[SQLITE]
CREATE TABLE IF NOT EXISTS or11 (CODIGO TEXT , OS FLOAT, OF FLOAT, QTDDE FLOAT, REQUISI INTEGER default 0, NRNOTA INTEGER default 0, SEQ INTEGER default 0, BAIXA DATE, TIPO TEXT , QTDEBAI FLOAT, DLIMITE DATE, DPEDI DATE, DLIMP DATE, RASTRO TEXT )

create index OR11_1 on or11 ( CODIGO,OS,REQUISI ) ;
create index OR11_2 on or11 ( REQUISI,OS ) ;
create index OR11_3 on or11 ( CODIGO,DLIMITE ) ;
create index OR11_4 on or11 ( CODIGO,DLIMP ) ;

