[DBML]
Table or11 {
"CODIGO" CHAR (24)
"OS" DECIMAL (8,2) [default: 0]
"OF" DECIMAL (12,2) [default: 0]
"QTDDE" DECIMAL (12,4) [default: 0]
"REQUISI" DECIMAL (8) [default: 0]
"NRNOTA" DECIMAL (5) [default: 0]
"SEQ" DECIMAL (3) [default: 0]
"BAIXA" DATETIME 
"TIPO" CHAR (1)
"QTDEBAI" DECIMAL (12,4) [default: 0]
"DLIMITE" DATETIME 
"DPEDI" DATETIME 
"DLIMP" DATETIME 
"RASTRO" CHAR (6)
  Indexes {
 ( CODIGO,OS,REQUISI )  [name: "OR11_1"]
