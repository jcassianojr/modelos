CREATE TABLE IF NOT EXISTS or11 (CODIGO CHAR(24), OS NUMERIC(8,2), OF NUMERIC(12,2), QTDDE NUMERIC(12,4), REQUISI INTEGER(8), NRNOTA INTEGER(5), SEQ INTEGER(3), BAIXA DATE, TIPO CHAR(1), QTDEBAI NUMERIC(12,4), DLIMITE DATE, DPEDI DATE, DLIMP DATE, RASTRO CHAR(6))

create index OR11_1 on or11 ( CODIGO,OS,REQUISI ) ;
create index OR11_2 on or11 ( REQUISI,OS ) ;
