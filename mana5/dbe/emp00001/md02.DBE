DBFDEF MD02
   CODIGO     C  12  0
   CODIGO1    C  12  0
   DESCRICAO  C 100  0
   DATA       D   8  0
   VALOR      N  12  4
   VARIACAO   N  12  4
   ACUMULADO  N  12  4
   ACUMULANU  N  12  4
   ACUMUGERA  N  12  4
   CODIGO2    C  12  0
   CODIGO3    C  12  0
ENDDEF
DEFINDEX MD02
   MD02-1 CODIGO+CODIGO1+DTOS(DATA) CODIGO,CODIGO1,DATA
   MD02-2 DATA DATA
   MD02-3 CODIGO CODIGO
   MD02-4 CODIGO+DTOS(DATA) CODIGO,DATA
ENDINDEX
ENDFILE

[MD02.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=4
MAINTAIN0=md02.CDX
TAG0=MD02-1
INDEX0=CODIGO+CODIGO1+DTOS(DATA)
INDEXFIELDS0=CODIGO,CODIGO1,DATA
TAG1=MD02-2
INDEX1=DATA
INDEXFIELDS1=DATA
TAG2=MD02-3
INDEX2=CODIGO
INDEXFIELDS2=CODIGO
TAG3=MD02-4
INDEX3=CODIGO+DTOS(DATA)
INDEXFIELDS3=CODIGO,DATA

[SQLITE]
CREATE TABLE IF NOT EXISTS md02 (CODIGO TEXT , CODIGO1 TEXT , DESCRICAO TEXT , DATA DATE, VALOR FLOAT, VARIACAO FLOAT, ACUMULADO FLOAT, ACUMULANU FLOAT, ACUMUGERA FLOAT, CODIGO2 TEXT , CODIGO3 TEXT )

create index MD02_1 on md02 ( CODIGO,CODIGO1,DATA ) ;
create index MD02_2 on md02 ( DATA ) ;
create index MD02_3 on md02 ( CODIGO ) ;
create index MD02_4 on md02 ( CODIGO,DATA ) ;

[MSSQL]
CREATE TABLE IF NOT EXISTS md02 (CODIGO VARCHAR(12), CODIGO1 VARCHAR(12), DESCRICAO VARCHAR(100), DATA DATETIME, VALOR NUMERIC(12,4), VARIACAO NUMERIC(12,4), ACUMULADO NUMERIC(12,4), ACUMULANU NUMERIC(12,4), ACUMUGERA NUMERIC(12,4), CODIGO2 VARCHAR(12), CODIGO3 VARCHAR(12))

create index MD02_1 on md02 ( CODIGO,CODIGO1,DATA ) ;
create index MD02_2 on md02 ( DATA ) ;
create index MD02_3 on md02 ( CODIGO ) ;
create index MD02_4 on md02 ( CODIGO,DATA ) ;

