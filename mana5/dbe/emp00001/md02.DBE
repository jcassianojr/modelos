CREATE TABLE md02 (CODIGO VARCHAR(12), CODIGO1 VARCHAR(12), DESCRICAO VARCHAR(100), DATA DATETIME, VALOR DOUBLE, VARIACAO DOUBLE, ACUMULADO DOUBLE, ACUMULANU DOUBLE, ACUMUGERA DOUBLE, CODIGO2 VARCHAR(12), CODIGO3 VARCHAR(12))

create index MD02_1 on md02 ( CODIGO,CODIGO1,DATA ) ;
create index MD02_2 on md02 ( DATA ) ;
