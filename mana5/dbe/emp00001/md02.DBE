create index MD02_4 on md02 ( CODIGO,DATA ) ;

[ORACLE]
CREATE TABLE IF NOT EXISTS md02 (CODIGO VARCHAR2 (12), CODIGO1 VARCHAR2 (12), DESCRICAO VARCHAR2 (100), DATA DATE, VALOR NUMBER(12,4)  DEFAULT 0, VARIACAO NUMBER(12,4)  DEFAULT 0, ACUMULADO NUMBER(12,4)  DEFAULT 0, ACUMULANU NUMBER(12,4)  DEFAULT 0, ACUMUGERA NUMBER(12,4)  DEFAULT 0, CODIGO2 VARCHAR2 (12), CODIGO3 VARCHAR2 (12))

create index MD02_1 on md02 ( CODIGO,CODIGO1,DATA ) ;
create index MD02_2 on md02 ( DATA ) ;
create index MD02_3 on md02 ( CODIGO ) ;
create index MD02_4 on md02 ( CODIGO,DATA ) ;

[DBML]
Table md02 {
"CODIGO" CHAR (12)
"CODIGO1" CHAR (12)
"DESCRICAO" CHAR (100)
"DATA" DATETIME 
"VALOR" DECIMAL (12,4) [default: 0]
"VARIACAO" DECIMAL (12,4) [default: 0]
"ACUMULADO" DECIMAL (12,4) [default: 0]
"ACUMULANU" DECIMAL (12,4) [default: 0]
"ACUMUGERA" DECIMAL (12,4) [default: 0]
"CODIGO2" CHAR (12)
"CODIGO3" CHAR (12)
  Indexes {
 ( CODIGO,CODIGO1,DATA )  [name: "MD02_1"]
 ( DATA )  [name: "MD02_2"]
 ( CODIGO )  [name: "MD02_3"]
 ( CODIGO,DATA )  [name: "MD02_4"]

 }
}
