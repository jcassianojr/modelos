CREATE TABLE IF NOT EXISTS md02 (CODIGO CHAR(12), CODIGO1 CHAR(12), DESCRICAO CHAR(100), DATA DATE, VALOR NUMERIC(12,4), VARIACAO NUMERIC(12,4), ACUMULADO NUMERIC(12,4), ACUMULANU NUMERIC(12,4), ACUMUGERA NUMERIC(12,4), CODIGO2 CHAR(12), CODIGO3 CHAR(12))

create index MD02_1 on md02 ( CODIGO,CODIGO1,DATA ) ;
create index MD02_2 on md02 ( DATA ) ;
create index MD02_3 on md02 ( CODIGO ) ;
create index MD02_4 on md02 ( CODIGO,DATA ) ;

[POSTGRESQL]
CREATE TABLE IF NOT EXISTS MD02 (CODIGO VARCHAR(12), CODIGO1 VARCHAR(12), DESCRICAO VARCHAR(100), DATA TIMESTAMP, VALOR NUMERIC(12,4), VARIACAO NUMERIC(12,4), ACUMULADO NUMERIC(12,4), ACUMULANU NUMERIC(12,4), ACUMUGERA NUMERIC(12,4), CODIGO2 VARCHAR(12), CODIGO3 VARCHAR(12))

create index MD02_1 on md02 ( CODIGO,CODIGO1,DATA ) ;
create index MD02_2 on md02 ( DATA ) ;
create index MD02_3 on md02 ( CODIGO ) ;
create index MD02_4 on md02 ( CODIGO,DATA ) ;

