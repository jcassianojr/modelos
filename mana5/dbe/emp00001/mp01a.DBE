create index MP01A_2 on mp01a ( CODMPSB,SEQ ) ;

[DBML]
Table mp01a {
"CODIGO" CHAR (12)
"SEQ" DECIMAL (3) [default: 0]
"CODMPSB" CHAR (12)
"NOMMPSB" CHAR (30)
  Indexes {
 ( CODIGO,SEQ )  [name: "MP01A_1"]
 ( CODMPSB,SEQ )  [name: "MP01A_2"]

 }
}
