DBFDEF MP01A
   CODIGO     C  12  0
   SEQ        N   3  0
   CODMPSB    C  12  0
   NOMMPSB    C  30  0
ENDDEF
DEFINDEX MP01A
   MP01A-1 CODIGO+STR(SEQ,3) CODIGO,SEQ
   MP01A-2 CODMPSB+STR(SEQ,3) CODMPSB,SEQ
ENDINDEX
ENDFILE

[MP01A.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=2
MAINTAIN0=mp01a.CDX
TAG0=MP01A-1
INDEX0=CODIGO+STR(SEQ,3)
INDEXFIELDS0=CODIGO,SEQ
TAG1=MP01A-2
INDEX1=CODMPSB+STR(SEQ,3)
INDEXFIELDS1=CODMPSB,SEQ

[SQLITE]
CREATE TABLE IF NOT EXISTS mp01a (CODIGO TEXT , SEQ INTEGER default 0, CODMPSB TEXT , NOMMPSB TEXT )

create index MP01A_1 on mp01a ( CODIGO,SEQ ) ;
create index MP01A_2 on mp01a ( CODMPSB,SEQ ) ;

