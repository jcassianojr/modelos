"DATA" DATETIME 
"TIPO1" CHAR (1)
"TIPO2" CHAR (1)
"CODIGO" CHAR (24)
"QTDE" DECIMAL (10,3) [default: 0]
"UNID" CHAR (2)
"OS" DECIMAL (8,2) [default: 0]
"ITEM" DECIMAL (3) [default: 0]
"OBS" CHAR (40)
"DISTRI" CHAR (1)
"RASTRO" CHAR (8)
"TECNICO" DECIMAL (8) [default: 0]
"NRNOTA" DECIMAL (8) [default: 0]
"CRM" DECIMAL (8) [default: 0]
"REQINT" DECIMAL (8) [default: 0]
"NUMMB01" DECIMAL (8) [default: 0]
"PRCMW02" DECIMAL (15,6) [default: 0]
"PRCMY04" DECIMAL (15,6) [default: 0]
"PRCMK02" DECIMAL (15,6) [default: 0]
"AUT" DECIMAL (8) [default: 0]
"NUMMW04" DECIMAL (8) [default: 0]
"NAOMEDIO" CHAR (1)
"FIRMA" DECIMAL (8) [default: 0]
"TIPO3" CHAR (3)
  Indexes {
 ( NUMERO )  [name: "MY01_1"]
 ( CODIGO,TIPO2,TIPO1 )  [name: "MY01_2"]
