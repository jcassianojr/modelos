DBFDEF MY01
   NUMERO     N   8  0
   DATA       D   8  0
   TIPO1      C   1  0
   TIPO2      C   1  0
   CODIGO     C  24  0
   QTDE       N  10  3
   UNID       C   2  0
   OS         N   8  2
   ITEM       N   3  0
   OBS        C  40  0
   DISTRI     C   1  0
   RASTRO     C   8  0
   TECNICO    N   8  0
   NRNOTA     N   8  0
   CRM        N   8  0
   REQINT     N   8  0
   NUMMB01    N   8  0
   PRCMW02    N  15  6
   PRCMY04    N  15  6
   PRCMK02    N  15  6
   AUT        N   8  0
   NUMMW04    N   8  0
   NAOMEDIO   C   1  0
   FIRMA      N   8  0
   TIPO3      C   3  0
ENDDEF
DEFINDEX MY01
   MY01-1 NUMERO NUMERO
   MY01-2 CODIGO+TIPO2+TIPO1 CODIGO,TIPO2,TIPO1
   MY01-3 STR(NRNOTA,8)+STR(NUMMB01,8) NRNOTA,NUMMB01
   MY01-4 OS OS
ENDINDEX
ENDFILE

[MY01.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=4
MAINTAIN0=my01.CDX
TAG0=MY01-1
INDEX0=NUMERO
INDEXFIELDS0=NUMERO
TAG1=MY01-2
INDEX1=CODIGO+TIPO2+TIPO1
INDEXFIELDS1=CODIGO,TIPO2,TIPO1
TAG2=MY01-3
INDEX2=STR(NRNOTA,8)+STR(NUMMB01,8)
INDEXFIELDS2=NRNOTA,NUMMB01
TAG3=MY01-4
INDEX3=OS
INDEXFIELDS3=OS

[SQLITE]
CREATE TABLE IF NOT EXISTS my01 (NUMERO INTEGER default 0, DATA DATE, TIPO1 TEXT , TIPO2 TEXT , CODIGO TEXT , QTDE FLOAT, UNID TEXT , OS FLOAT, ITEM INTEGER default 0, OBS TEXT , DISTRI TEXT , RASTRO TEXT , TECNICO INTEGER default 0, NRNOTA INTEGER default 0, CRM INTEGER default 0, REQINT INTEGER default 0, NUMMB01 INTEGER default 0, PRCMW02 FLOAT, PRCMY04 FLOAT, PRCMK02 FLOAT, AUT INTEGER default 0, NUMMW04 INTEGER default 0, NAOMEDIO TEXT , FIRMA INTEGER default 0, TIPO3 TEXT )

create index MY01_1 on my01 ( NUMERO ) ;
create index MY01_2 on my01 ( CODIGO,TIPO2,TIPO1 ) ;
create index MY01_3 on my01 ( NRNOTA,NUMMB01 ) ;
create index MY01_4 on my01 ( OS ) ;

