create index TECNICO on mp04a ( TECNICO ) ;
create index CURSO on mp04a ( CURSO ) ;

[ORACLE]
CREATE TABLE IF NOT EXISTS mp04a (TECNICO NUMBER(8)  DEFAULT 0, CURSO VARCHAR2 (20), DESCUR VARCHAR2 (120), TREIN NUMBER(8)  DEFAULT 0, NUMANT NUMBER(8)  DEFAULT 0, CARHOR NUMBER(8)  DEFAULT 0)

create index TECNICO on mp04a ( TECNICO ) ;
create index CURSO on mp04a ( CURSO ) ;

[DBML]
