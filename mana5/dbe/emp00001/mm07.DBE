DBFDEF MM07
   REQDEV     N   8  0
   CLIENTE    N   8  0
   COGCLI     C  12  0
   NF         N   8  0
   NFC        N   8  0
   PRODUTO    C  24  0
   DATANF     D   8  0
   DATADEV    D   8  0
   VALOR      N  12  2
ENDDEF
DEFINDEX MM07
   MM07-1 REQDEV REQDEV
ENDINDEX
ENDFILE

[MM07.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=1
MAINTAIN0=mm07.CDX
TAG0=MM07-1
INDEX0=REQDEV
