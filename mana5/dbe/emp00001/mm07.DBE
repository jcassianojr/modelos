[SQLITE]
CREATE TABLE IF NOT EXISTS mm07 (REQDEV INTEGER default 0, CLIENTE INTEGER default 0, COGCLI TEXT , NF INTEGER default 0, NFC INTEGER default 0, PRODUTO TEXT , DATANF DATE, DATADEV DATE, VALOR FLOAT)

create index MM07_1 on mm07 ( REQDEV ) ;

