create index APURA5_1 on apura5 ( CLIENTE,CODIGO ) ;
create index APURA5_2 on apura5 ( PERCLI,CODIGO ) ;
create index APURA5_3 on apura5 ( CODIGO ) ;
create index APURA5_4 on apura5 ( PERLUC ) ;
create index APURA5_5 on apura5 ( DIFLUC ) ;

