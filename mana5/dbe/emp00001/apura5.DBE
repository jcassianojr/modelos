DBFDEF APURA5
   CLIENTE    N   8  0
   COGCLI     C  12  0
   GRUPO      C  12  0
   CODIGO     C  24  0
   NOME       C  40  0
   ICM        N   5  2
   PARTI      N   8  2
   PPLAN      N  10  4
   PPLANL     C   1  0
   PPCAL      N  10  4
   QTDDE      N  12  0
   VALORMER   N  12  2
   VALORTOT   N  12  2
   PRECOM     N   8  2
   PERCLI     N   8  2
   PERLUC     N   8  2
   VALLUC     N  12  2
   DIFLUC     N   8  2
   SUBGER     C   2  0
   CLITOTPER  N   8  2
   CLITOTVAL  N  12  2
ENDDEF
DEFINDEX APURA5
   APURA5-1 STR(CLIENTE,8)+CODIGO CLIENTE,CODIGO
   APURA5-2 STR(PERCLI,6,2)+CODIGO PERCLI,CODIGO
   APURA5-3 CODIGO CODIGO
   APURA5-4 PERLUC PERLUC
   APURA5-5 DIFLUC DIFLUC
ENDINDEX
ENDFILE

[APURA5.DBF]
CAMINHO=c:\temp\dbf\
DRIVER=DBFCDX
NUMMAINTAINED=5
MAINTAIN0=apura5.CDX
TAG0=APURA5-1
INDEX0=STR(CLIENTE,8)+CODIGO
INDEXFIELDS0=CLIENTE,CODIGO
TAG1=APURA5-2
INDEX1=STR(PERCLI,6,2)+CODIGO
INDEXFIELDS1=PERCLI,CODIGO
TAG2=APURA5-3
INDEX2=CODIGO
INDEXFIELDS2=CODIGO
TAG3=APURA5-4
INDEX3=PERLUC
INDEXFIELDS3=PERLUC
TAG4=APURA5-5
INDEX4=DIFLUC
INDEXFIELDS4=DIFLUC

