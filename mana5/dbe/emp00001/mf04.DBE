"CIDPRA" CHAR (30)
"ESTPRA" CHAR (2)
"AREA1" CHAR (70)
"AREA2" CHAR (70)
"AREA3" CHAR (70)
"AREA4" CHAR (70)
"AREA5" CHAR (70)
"FERIADO" DATETIME 
